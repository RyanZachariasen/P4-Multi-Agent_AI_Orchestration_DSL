prompt1="Save Important Documents"
prompt2="Summarise it"

//memory keyword to store the output
memory read_pdfs(assistant_agent:Text){
    input:
        input_text->{extract_pdf(path)}
        input_text->{prompt1}
    
}


// we're just gonna roleplay that the assistant agent has read multiple pdf(as an assistant) and the writer agent has the role of rewriting
flow summarise (read_pdfs, writer_agent:Text){ 
    input:
        input_text -> {assistant_agent.storedMemory}
        input_text-> {prompt2}

}